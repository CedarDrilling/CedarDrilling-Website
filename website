<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cedar Drilling – EPC Africa</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #0c0f18;
    --dark: #111827;
    --panel: #161d2e;
    --border: #1e2d4a;
    --cedar: #1e5bbc;
    --cedar-light: #3a74d4;
    --cedar-dim: rgba(30,91,188,0.15);
    --white: #eef2f8;
    --muted: #7a8aaa;
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'DM Sans', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    font-weight: 300;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ─── NOISE TEXTURE ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 68px;
    background: rgba(10,10,8,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .nav-logo-mark {
    width: 36px;
    height: 36px;
    background: var(--cedar);
    clip-path: polygon(50% 0%, 61% 11%, 75% 7%, 78% 22%, 92% 28%, 87% 42%, 96% 54%, 84% 63%, 84% 78%, 70% 80%, 62% 93%, 50% 87%, 38% 93%, 30% 80%, 16% 78%, 16% 63%, 4% 54%, 13% 42%, 8% 28%, 22% 22%, 25% 7%, 39% 11%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .nav-logo-text {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--white);
  }

  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--cedar); }

  .nav-cta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--white);
    background: var(--cedar);
    border: none;
    padding: 10px 22px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
  }
  .nav-cta:hover { background: var(--cedar-light); }

  /* ─── HERO ─── */
  #hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    padding: 160px 64px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--cedar);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero-tag::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--cedar);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(72px, 8vw, 120px);
    line-height: 0.92;
    letter-spacing: 2px;
    color: var(--white);
    margin-bottom: 32px;
  }

  h1 em {
    color: var(--cedar);
    font-style: normal;
  }

  .hero-sub {
    font-size: 16px;
    font-weight: 300;
    color: var(--muted);
    max-width: 440px;
    margin-bottom: 48px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .btn-primary {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--white);
    background: var(--cedar);
    border: none;
    padding: 14px 32px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--cedar-light); transform: translateY(-1px); }

  .btn-ghost {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--white);
    background: transparent;
    border: 1px solid var(--border);
    padding: 14px 32px;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    display: inline-block;
  }
  .btn-ghost:hover { border-color: var(--cedar); color: var(--cedar); }

  .hero-right {
    position: relative;
    overflow: hidden;
  }

  .hero-right::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--black) 0%, transparent 40%);
    z-index: 1;
  }

  .hero-bg-graphic {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 70% 50%, rgba(200,132,26,0.12) 0%, transparent 70%),
      linear-gradient(180deg, var(--black) 0%, transparent 30%, transparent 70%, var(--black) 100%);
    z-index: 0;
  }

  /* Grid of lines */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.4;
    z-index: 0;
  }

  .hero-stat-block {
    position: absolute;
    right: 64px;
    bottom: 80px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: flex-end;
  }

  .hero-stat {
    text-align: right;
  }

  .hero-stat-num {
    font-family: var(--font-display);
    font-size: 52px;
    color: var(--cedar);
    line-height: 1;
  }

  .hero-stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 4px;
  }

  /* The big diagonal text */
  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-15deg);
    font-family: var(--font-display);
    font-size: 200px;
    color: rgba(200,132,26,0.04);
    white-space: nowrap;
    pointer-events: none;
    z-index: 0;
    letter-spacing: 10px;
  }

  /* Partners strip */
  .partners-strip {
    background: var(--panel);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 20px 64px;
    display: flex;
    align-items: center;
    gap: 48px;
    overflow: hidden;
  }

  .partners-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-right: 48px;
    border-right: 1px solid var(--border);
  }

  .partner-name {
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: 3px;
    color: rgba(240,237,230,0.35);
    white-space: nowrap;
    transition: color 0.2s;
  }
  .partner-name:hover { color: var(--cedar); }

  /* ─── SECTIONS ─── */
  section {
    padding: 120px 64px;
  }

  .section-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--cedar);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-tag::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--cedar);
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 80px);
    letter-spacing: 2px;
    line-height: 1;
    color: var(--white);
    margin-bottom: 24px;
  }

  h2 em { color: var(--cedar); font-style: normal; }

  .section-intro {
    font-size: 16px;
    color: var(--muted);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: 64px;
  }

  /* ─── SERVICES ─── */
  #services {
    background: var(--dark);
    position: relative;
    overflow: hidden;
  }

  #services::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(200,132,26,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .service-card {
    background: var(--dark);
    padding: 40px 36px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
    cursor: default;
  }

  .service-card:hover {
    background: var(--panel);
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 0;
    background: var(--cedar);
    transition: height 0.3s;
  }
  .service-card:hover::before { height: 100%; }

  .service-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cedar);
    letter-spacing: 2px;
    margin-bottom: 24px;
  }

  .service-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 20px;
    color: var(--cedar);
  }

  .service-title {
    font-family: var(--font-display);
    font-size: 26px;
    letter-spacing: 1px;
    color: var(--white);
    margin-bottom: 12px;
  }

  .service-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
  }

  .service-items {
    margin-top: 20px;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .service-items li {
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(240,237,230,0.5);
    padding-left: 16px;
    position: relative;
    letter-spacing: 0.5px;
  }

  .service-items li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--cedar);
    font-size: 10px;
  }

  /* ─── PROJECTS ─── */
  #projects {
    background: var(--black);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .project-card {
    background: var(--dark);
    padding: 48px 44px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .project-card:hover { background: var(--panel); }

  .project-card.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .project-tags {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--border);
    color: var(--muted);
  }

  .tag.energy { border-color: rgba(200,132,26,0.4); color: var(--cedar); }
  .tag.mining { border-color: rgba(100,130,100,0.4); color: #7ab87a; }
  .tag.wind { border-color: rgba(80,140,200,0.4); color: #7ab4e0; }

  .project-title {
    font-family: var(--font-display);
    font-size: 32px;
    letter-spacing: 1px;
    color: var(--white);
    margin-bottom: 12px;
    line-height: 1.1;
  }

  .project-location {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--cedar);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .project-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
  }

  .project-mw {
    font-family: var(--font-display);
    font-size: 96px;
    color: rgba(30,91,188,0.25);
    line-height: 1;
    letter-spacing: 2px;
    margin-top: 16px;
  }

  /* ─── GEOGRAPHY ─── */
  #geography {
    background: var(--panel);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .geo-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .geo-map {
    position: relative;
    aspect-ratio: 4/5;
    background: var(--dark);
    border: 1px solid var(--border);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* SVG Africa outline */
  .africa-svg {
    width: 88%;
    height: 88%;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .geo-pins {
    position: absolute;
    inset: 0;
  }

  .pin {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: default;
  }

  .pin-dot {
    width: 10px;
    height: 10px;
    background: var(--cedar);
    border-radius: 50%;
    position: relative;
    animation: pulse 2.5s ease-in-out infinite;
  }

  .pin-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid var(--cedar);
    animation: pulse-ring 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }

  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.7; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  .pin-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--cedar);
    text-transform: uppercase;
    white-space: nowrap;
    background: var(--dark);
    padding: 2px 6px;
  }

  .geo-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .geo-country {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
  }

  .geo-country:first-child { border-top: 1px solid var(--border); }

  .geo-country-dot {
    width: 8px;
    height: 8px;
    background: var(--cedar);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .geo-country-name {
    font-family: var(--font-display);
    font-size: 24px;
    letter-spacing: 1px;
    color: var(--white);
    flex: 1;
  }

  .geo-country-sectors {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--muted);
    text-align: right;
  }

  /* ─── WHY ─── */
  #why {
    background: var(--black);
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 0;
  }

  .pillar {
    background: var(--dark);
    padding: 40px 28px;
    transition: background 0.3s;
  }
  .pillar:hover { background: var(--panel); }

  .pillar-icon {
    width: 40px;
    height: 40px;
    color: var(--cedar);
    margin-bottom: 20px;
  }

  .pillar-title {
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: 1px;
    color: var(--white);
    margin-bottom: 10px;
  }

  .pillar-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
  }

  /* ─── HSE STRIP ─── */
  .hse-strip {
    background: var(--cedar);
    padding: 40px 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .hse-title {
    font-family: var(--font-display);
    font-size: 32px;
    letter-spacing: 2px;
    color: var(--white);
  }

  .hse-items {
    display: flex;
    gap: 48px;
  }

  .hse-item {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--white);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hse-check {
    width: 18px;
    height: 18px;
    background: rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ─── CONTACT ─── */
  #contact {
    background: var(--dark);
    border-top: 1px solid var(--border);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .contact-block {}

  .contact-block-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--cedar);
    margin-bottom: 10px;
  }

  .contact-block-value {
    font-size: 15px;
    color: var(--white);
    line-height: 1.6;
  }

  .contact-block-value a {
    color: var(--white);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-block-value a:hover { color: var(--cedar); }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    background: var(--black);
    border: 1px solid var(--border);
    color: var(--white);
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    outline: none;
    transition: border-color 0.2s;
    appearance: none;
    -webkit-appearance: none;
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    border-color: var(--cedar);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }

  .form-submit {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--white);
    background: var(--cedar);
    border: none;
    padding: 16px 32px;
    cursor: pointer;
    transition: background 0.2s;
    align-self: flex-start;
  }
  .form-submit:hover { background: var(--cedar-light); }

  /* ─── FOOTER ─── */
  footer {
    background: var(--black);
    border-top: 1px solid var(--border);
    padding: 32px 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: 3px;
    color: rgba(240,237,230,0.3);
  }

  .footer-reg {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: rgba(240,237,230,0.2);
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: rgba(240,237,230,0.2);
  }

  /* ─── SCROLL REVEAL ─── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1100px) {
    #hero { grid-template-columns: 1fr; }
    .hero-right { display: none; }
